{
  "name": "@fhir-dsl/generator",
  "version": "0.9.2",
  "description": "FHIR TypeScript code generator from HL7 StructureDefinitions and SearchParameters",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@fhir-dsl/terminology": "workspace:*",
    "@fhir-dsl/utils": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "author": "Abdelhadi Sabani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/awbx/fhir-dsl.git",
    "directory": "packages/generator"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "fhir",
    "codegen",
    "typescript",
    "hl7",
    "healthcare"
  ]
}
