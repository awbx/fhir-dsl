{
  "name": "@fhir-dsl/types",
  "version": "0.39.0",
  "description": "TypeScript type definitions for FHIR R4/R5 resources, datatypes, and search parameters",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist"
  ],
  "author": "Abdelhadi Sabani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/awbx/fhir-dsl.git",
    "directory": "packages/types"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "fhir",
    "types",
    "typescript",
    "hl7",
    "healthcare",
    "r4",
    "r5"
  ]
}
