{
  "name": "@fhir-dsl/smart",
  "version": "0.23.0",
  "description": "SMART on FHIR v2 authentication for @fhir-dsl — Backend Services, App Launch (PKCE), scopes, and discovery",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@fhir-dsl/core": "workspace:*",
    "jose": "^5.9.6"
  },
  "files": [
    "dist"
  ],
  "author": "Abdelhadi Sabani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/awbx/fhir-dsl.git",
    "directory": "packages/smart"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "fhir",
    "smart-on-fhir",
    "oauth",
    "oauth2",
    "pkce",
    "healthcare",
    "hl7",
    "typescript"
  ]
}
