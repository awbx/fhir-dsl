{
  "name": "@fhir-dsl/cli",
  "version": "0.1.0",
  "description": "CLI tool for generating type-safe FHIR TypeScript types from HL7 specs and profiles",
  "type": "module",
  "bin": {
    "fhir-gen": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@fhir-dsl/generator": "workspace:*",
    "commander": "^13.0.0"
  },
  "files": [
    "dist"
  ],
  "author": "Abdelhadi Sabani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/awbx/fhir-dsl.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "fhir",
    "cli",
    "codegen",
    "typescript",
    "hl7",
    "healthcare"
  ]
}
