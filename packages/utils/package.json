{
  "name": "@fhir-dsl/utils",
  "version": "0.42.1",
  "description": "Shared utilities for FHIR DSL packages",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist"
  ],
  "author": "Abdelhadi Sabani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/awbx/fhir-dsl.git",
    "directory": "packages/utils"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "fhir",
    "utilities",
    "typescript"
  ]
}
