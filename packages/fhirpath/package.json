{
  "name": "@fhir-dsl/fhirpath",
  "version": "0.34.0",
  "description": "Type-safe FHIRPath expression builder with autocomplete",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@fhir-dsl/types": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "author": "Abdelhadi Sabani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/awbx/fhir-dsl.git",
    "directory": "packages/fhirpath"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "fhir",
    "fhirpath",
    "typescript",
    "type-safe",
    "expression-builder",
    "healthcare",
    "hl7"
  ]
}
