{
  "name": "fhir-dsl",
  "version": "1.0.0",
  "private": true,
  "description": "Type-safe FHIR client & code generator, inspired by Kysely",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "dev": "pnpm -r run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "version:bump": "node scripts/bump-version.mjs"
  },
  "keywords": [
    "fhir",
    "typescript",
    "type-safe",
    "dsl"
  ],
  "author": "Abdelhadi Sabani",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@fhir-dsl/core": "workspace:*",
    "@fhir-dsl/runtime": "workspace:*",
    "@fhir-dsl/types": "workspace:*"
  }
}
