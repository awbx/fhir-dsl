{
  "name": "@fhir-dsl/runtime",
  "version": "0.33.0",
  "description": "Runtime execution layer for FHIR DSL queries with pagination and error handling",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@fhir-dsl/core": "workspace:*",
    "@fhir-dsl/types": "workspace:*"
  },
  "files": [
    "dist"
  ],
  "author": "Abdelhadi Sabani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/awbx/fhir-dsl.git",
    "directory": "packages/runtime"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "fhir",
    "runtime",
    "typescript",
    "healthcare"
  ]
}
