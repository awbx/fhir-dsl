{
  "name": "fhir-dsl",
  "version": "0.18.0",
  "private": true,
  "description": "Type-safe FHIR client & code generator, inspired by Kysely",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "test": "vitest run",
    "dev": "pnpm -r run dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:unsafefix": "biome check --write --unsafe .",
    "format": "biome format --write .",
    "changelog": "node scripts/generate-changelog.mjs --write",
    "version:bump": "node scripts/bump-version.mjs",
    "prepare": "husky"
  },
  "keywords": [
    "fhir",
    "typescript",
    "type-safe",
    "dsl"
  ],
  "author": "Abdelhadi Sabani",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "husky": "^9.1.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@fhir-dsl/core": "workspace:*",
    "@fhir-dsl/runtime": "workspace:*",
    "@fhir-dsl/types": "workspace:*"
  },
  "pnpm": {
    "overrides": {
      "webpack": "~5.105.0"
    }
  }
}
