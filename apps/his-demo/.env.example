# Anthropic API key for the chatbot's server route. NEVER commit a real value.
ANTHROPIC_API_KEY=sk-ant-...

# Default upstream FHIR server for queries (R4).
FHIR_BASE_URL=https://hapi.fhir.org/baseR4

# Optional bearer for the MCP server's outbound calls.
# FHIR_BEARER_TOKEN=...

# SMART-on-FHIR via the Smart Health IT launcher.
# The launcher hands control to /launch with a real `launch` token; our /launch
# route then runs PKCE and lands the user back at /callback.
VITE_SMART_LAUNCHER_URL=https://launch.smarthealthit.org
VITE_SMART_LAUNCHER_FHIR_VERSION=r4
VITE_SMART_CLIENT_ID=fhir-dsl-demo
VITE_SMART_REDIRECT_URI=http://localhost:3000/callback
VITE_SMART_APP_LAUNCH_URL=http://localhost:3000/launch
VITE_SMART_SCOPE=launch openid fhirUser patient/*.read offline_access
